    },
    {
      "info": {
        "name": "Activity",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Perforce List Activity Entries",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "{scheme}://{host}/api/v9/activity",
            "params": [
              {
                "name": "change",
                "value": "10",
                "type": "query",
                "description": "Filter activity by changelist ID."
