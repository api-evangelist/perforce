                  "value": ""
                },
                {
                  "name": "target",
                  "value": ""
                },
                {
                  "name": "topic",
                  "value": ""
                },
                {
                  "name": "description",
                  "value": ""
                },
                {
                  "name": "change",
                  "value": ""
                },
                {
                  "name": "streams[]",
                  "value": ""
                },
                {
                  "name": "link",
                  "value": ""
                }
              ]
            }
          },
          "docs": "Creates a new entry in the activity stream."
        }
